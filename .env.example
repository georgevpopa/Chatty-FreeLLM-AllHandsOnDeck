# Mistral — 1 req/sec free — https://console.mistral.ai
MISTRAL_API_KEY=

# OpenRouter — free models available — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── App config ───────────────────────────────────────────────────────────────
LITELLM_PROXY_PORT=4000
APP_PORT=8000
